# Alchemy API key for Base mainnet (transfer history + CLAWD balance checks)
ALCHEMY_KEY=

# Anthropic API key for Claude story generation
ANTHROPIC_KEY=

# HMAC secret for signed session tokens (recommended in production)
# Falls back to ANTHROPIC_KEY if unset — set a dedicated value for production
SESSION_SECRET=

# Optional: restrict CORS to your deployed origin
# ALLOWED_ORIGIN=https://your-app.vercel.app
